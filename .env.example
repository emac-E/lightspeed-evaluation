# LightSpeed Evaluation & OKP-MCP Agent Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is automatically loaded when running the agent, so you don't need to
# manually export these variables in your terminal.

# For lightspeed-evaluation (Gemini LLM-as-judge)
# This is the primary credentials file used for running evaluations
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# For OKP-MCP Agent LLM Advisor (Claude via Vertex AI)
# IMPORTANT: The agent uses Application Default Credentials (ADC) for Claude.
# Run this in your terminal once (persists globally):
#   gcloud auth application-default login
# This sets up ~/.config/gcloud/application_default_credentials.json
ANTHROPIC_VERTEX_PROJECT_ID=your-anthropic-vertex-project-id

# Optional: Use separate credentials for Claude (avoids conflicts)
# If you get permission errors with ADC, you can use a service account key instead:
# GOOGLE_CLAUDE_CREDENTIALS=/path/to/claude-service-account-key.json
